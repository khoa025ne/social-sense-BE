{
  "_comment": "Copy file này thành appsettings.Secrets.json và điền thông tin thực. KHÔNG commit appsettings.Secrets.json lên git.",

  "PayOs": {
    "ClientId":      "FILL_YOUR_CLIENT_ID",
    "ApiKey":        "FILL_YOUR_API_KEY",
    "ChecksumKey":   "FILL_YOUR_CHECKSUM_KEY",
    "ReturnUrl":     "https://yourdomain.com/payment/success",
    "CancelUrl":     "https://yourdomain.com/payment/cancel",
    "BaseUrl":       "https://api-merchant.payos.vn",
    "ExpiredAfterSeconds": 900,
    "ProMonthlyPrice":        50000,
    "EnterpriseMonthlyPrice": 79000
  },

  "ConnectionStrings": {
    "Default": "Server=localhost;Port=3306;Database=socialsense;User=root;Password=YOUR_PASSWORD;"
  },

  "Jwt": {
    "Secret": "FILL_YOUR_JWT_SECRET_MIN_32_CHARS"
  },

  "AiProviderKeys": [
    {
      "label": "OpenRouter-Key1",
      "keyValue": "FILL_YOUR_OPENROUTER_KEY",
      "provider": "openrouter",
      "modelOverride": "meta-llama/llama-4-scout"
    },
    {
      "label": "Groq-Key1",
      "keyValue": "FILL_YOUR_GROQ_KEY",
      "provider": "groq",
      "modelOverride": "meta-llama/llama-4-scout-17b-16e-instruct"
    }
  ]
}
